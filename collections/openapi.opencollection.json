            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://translation.googleapis.com/v3/projects/:projectId/locations/:location:translateText",
            "params": [
              {
                "name": "projectId",
                "value": "",
                "type": "path"
              },
              {
                "name": "location",
                "value": "",
                "type": "path"
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
            }
          },
          "docs": "Translates input text from one language to another."
